# CAPABILITY DETECTION
# ---------------------------------------------------------------------------

typeset -gi _zui_unicode=-1 _zui_color=-1
typeset -g _zui_glyphs_done="" _zui_glyphs_active_a="" _zui_glyphs_active_b=""
typeset -g _zui_glyphs_pending="" _zui_glyphs_fail="" _zui_glyphs_skip="" _zui_glyphs_ok=""
typeset -g _zui_glyphs_fill="" _zui_glyphs_edge="" _zui_glyphs_head="" _zui_glyphs_track=""
typeset -g _zui_glyphs_frame_l="" _zui_glyphs_frame_r="" _zui_glyphs_sep="" _zui_glyphs_arrow=""
typeset -g _zui_glyphs_block_fill="" _zui_glyphs_block_empty=""

__z::ui::init_glyphs() {
  emulate -L zsh

  if z::ui::supports_unicode; then
    _zui_glyphs_done='●' _zui_glyphs_active_a='◉' _zui_glyphs_active_b='◎'
    _zui_glyphs_pending='○' _zui_glyphs_fail='✗' _zui_glyphs_skip='◌' _zui_glyphs_ok='✓'
    _zui_glyphs_fill='━' _zui_glyphs_edge='▓' _zui_glyphs_head='╸' _zui_glyphs_track='─'
    _zui_glyphs_frame_l='⟨' _zui_glyphs_frame_r='⟩' _zui_glyphs_sep='│' _zui_glyphs_arrow='▸'
    _zui_glyphs_block_fill='█' _zui_glyphs_block_empty='░'
  else
    _zui_glyphs_done='#' _zui_glyphs_active_a='*' _zui_glyphs_active_b='*'
    _zui_glyphs_pending='.' _zui_glyphs_fail='x' _zui_glyphs_skip='-' _zui_glyphs_ok='v'
    _zui_glyphs_fill='=' _zui_glyphs_edge='=' _zui_glyphs_head='>' _zui_glyphs_track='-'
    _zui_glyphs_frame_l='[' _zui_glyphs_frame_r=']' _zui_glyphs_sep='|' _zui_glyphs_arrow='>'
    _zui_glyphs_block_fill='#' _zui_glyphs_block_empty='.'
  fi
}

z::ui::is_tty() {
  emulate -L zsh
  local stream="${1:-2}"
  case $stream in
    1) [[ -t 1 ]] ;;
    2) [[ -t 2 ]] ;;
    *) return 1 ;;
  esac
}

z::ui::supports_color() {
  emulate -L zsh

  if (( _zui_color >= 0 )); then
    (( _zui_color )) && return 0
    return 1
  fi

  if [[ -n ${NO_COLOR-} ]] || [[ ${TERM:-} == dumb ]] || ! z::ui::is_tty 2; then
    _zui_color=0
    return 1
  fi

  if [[ -n ${_zlog_color_cache[mode]:-} && ${_zlog_color_cache[mode]} == none ]]; then
    _zui_color=0
    return 1
  fi

  if (( $+commands[tput] )) && tput setaf 1 >/dev/null 2>&1; then
    _zui_color=1
    return 0
  fi

  _zui_color=1
  return 0
}

z::ui::supports_unicode() {
  emulate -L zsh

  if (( _zui_unicode >= 0 )); then
    (( _zui_unicode )) && return 0
    return 1
  fi

  if [[ ${LANG:-}${LC_ALL:-}${LC_CTYPE:-} == *[Uu][Tt][Ff]-8* ]] &&
     [[ ${TERM:-} != dumb ]]; then
    _zui_unicode=1
    return 0
  fi

  _zui_unicode=0
  return 1
}

# ---------------------------------------------------------------------------
# TERMINAL DIMENSIONS
# ---------------------------------------------------------------------------

z::ui::width() {
  emulate -L zsh

  local cached
  if cached=$(z::cache::get "ui:term_width" 2>/dev/null); then
    print -r -- "$cached"
    return 0
  fi

  typeset -i width=80
  local columns_current=${COLUMNS:-}

  if [[ $columns_current == <-> ]]; then
    ((width = 10#$columns_current))
  elif (($+commands[tput])); then
    local tput_width
    if tput_width=$(tput cols 2>/dev/null) && [[ $tput_width == <-> ]]; then
      ((width = 10#$tput_width))
    fi
  fi

  z::cache::set "ui:term_width" "$width" --ttl 1 2>/dev/null
  print -r -- "$width"
  return 0
}

z::ui::height() {
  emulate -L zsh

  local cached
  if cached=$(z::cache::get "ui:term_height" 2>/dev/null); then
    print -r -- "$cached"
    return 0
  fi

  typeset -i rows=24
  local lines_current=${LINES:-}

  if [[ $lines_current == <-> ]]; then
    ((rows = 10#$lines_current))
  elif (($+commands[tput])); then
    local tput_height
    if tput_height=$(tput lines 2>/dev/null) && [[ $tput_height == <-> ]]; then
      ((rows = 10#$tput_height))
    fi
  fi

  z::cache::set "ui:term_height" "$rows" --ttl 1 2>/dev/null
  print -r -- "$rows"
  return 0
}

z::ui::watch_resize() {
  emulate -L zsh

  if (( ${+functions[TRAPWINCH]} )); then
    return 0
  fi

  TRAPWINCH() {
    z::cache::del "ui:term_width" 2>/dev/null
    z::cache::del "ui:term_height" 2>/dev/null
  }
  return 0
}

# ---------------------------------------------------------------------------
# TERMINAL CLEARING
# ---------------------------------------------------------------------------

z::ui::clear_line() {
  emulate -L zsh

  local arg
  typeset -i force=0 newline=1

  for arg in "$@"; do
    case $arg in
    -f | --force)
      force=1
      ;;
    -n | --no-newline)
      newline=0
      ;;
    --)
      break
      ;;
    *)
      return 1
      ;;
    esac
  done

  ((force == 0)) && [[ ! -t 2 ]] && return 0

  printf '\r\e[K' >&2
  ((newline)) && printf '\n' >&2
  return 0
}

z::ui::clear() {
  emulate -L zsh

  if [[ -t 2 ]]; then
    printf '\e[H\e[2J' >&2
  elif [[ -t 1 ]]; then
    clear
  fi

  return 0
}

# ---------------------------------------------------------------------------
# FORMATTING UTILITIES
# ---------------------------------------------------------------------------

z::util::comma() {
  emulate -L zsh
  setopt localoptions typeset_silent

  local n="${1:-0}"
  local sign=''

  if [[ $n == -* ]]; then
    sign='-'
    n="${n#-}"
  fi

  if [[ $n != <-> ]]; then
    print -r -- "${sign}${n}"
    return 0
  fi

  typeset -i len
  ((len = ${#n}))

  if ((len <= 3)); then
    print -r -- "${sign}${n}"
    return 0
  fi

  local result="" chunk
  typeset -i pos remainder

  ((remainder = len % 3))
  if ((remainder > 0)); then
    result="${n[1,remainder]}"
    ((pos = remainder + 1))
  else
    ((pos = 1))
  fi

  while ((pos <= len)); do
    chunk="${n[pos,pos+2]}"
    if [[ -n $result ]]; then
      result="${result},${chunk}"
    else
      result="$chunk"
    fi
    ((pos += 3))
  done

  print -r -- "${sign}${result}"
  return 0
}

z::util::truncate() {
  emulate -L zsh

  local text="${1:-}" max="${2:-12}"

  if [[ $max != <-> ]]; then
    return 1
  fi

  typeset -i max_i=${2:-12}
  (( max_i < 1 )) && max_i=1

  if (( ${#text} <= max_i )); then
    print -r -- "$text"
    return 0
  fi

  if (( max_i == 1 )); then
    print -r -- "…"
    return 0
  fi

  typeset -i keep=$(( (max_i - 1) / 2 ))
  print -r -- "${text[1,keep]}…${text: -keep}"
  return 0
}

z::util::duration() {
  emulate -L zsh

  local raw="${1:-0}"
  local -F seconds=0

  if [[ $raw == <-> ]]; then
    (( seconds = raw ))
  elif [[ $raw == *.* ]]; then
    seconds=$raw
  else
    print -r -- "${raw}s"
    return 0
  fi

  if (( seconds < 1 )); then
    printf '%.0fms\n' $(( seconds * 1000 ))
  elif (( seconds < 60 )); then
    printf '%.1fs\n' "$seconds"
  else
    typeset -i mins secs
    (( mins = seconds / 60 ))
    (( secs = seconds % 60 ))
    printf '%dm %02ds\n' "$mins" "$secs"
  fi
  return 0
}

# Elapsed seconds since an EPOCHREALTIME or integer epoch stamp.
__z::ui::elapsed_since() {
  emulate -L zsh
  local since="${1:-}"
  local -F now start elapsed=0

  if [[ -z $since ]]; then
    REPLY=""
    return 1
  fi

  now=${EPOCHREALTIME:-$SECONDS}
  if [[ $since == *.* ]]; then
    start=$since
  else
    start=$since.0
  fi

  elapsed=$(( now - start ))
  (( elapsed < 0 )) && elapsed=0
  REPLY=$elapsed
  return 0
}

z::ui::box() {
  emulate -L zsh

  local title="${1:-}" width="${2:-0}"
  shift 2
  local -a lines=("$@")
  local line top bottom inner max_len=0
  typeset -i box_width

  if [[ $width == <-> && width -gt 0 ]]; then
    box_width=$width
  else
    box_width=$(z::ui::width)
    (( box_width > 80 )) && box_width=80
  fi

  for line in "${lines[@]}"; do
    (( ${#line} > max_len )) && max_len=${#line}
  done
  (( ${#title} + 4 > max_len )) && max_len=$(( ${#title} + 4 ))

  typeset -i inner_width=$(( box_width - 4 ))
  (( inner_width < 10 )) && inner_width=10
  (( max_len > inner_width )) && max_len=$inner_width

  printf -v top '%*s' "$(( max_len + 2 ))" ''
  top=${top// /─}
  printf -v bottom '%*s' "$(( max_len + 2 ))" ''
  bottom=${bottom// /─}

  if [[ -n $title ]]; then
    printf '┌ %s %s\n' "$title" "${top:${#title}+2}" >&2
  else
    printf '┌%s\n' "$top" >&2
  fi

  for line in "${lines[@]}"; do
    line=$(z::util::truncate "$line" "$inner_width")
    printf '│ %-*s │\n' "$max_len" "$line" >&2
  done

  printf '└%s\n' "$bottom" >&2
  return 0
}

