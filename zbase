#!/usr/bin/env zsh
# =============================================================================
# zbase — z::opt  &  z::probe
#
# Description:
#   Option parsing, input validation, filesystem probing, command/function
#   introspection, variable management, environment management, and execution
#   safety scanning utilities for the zbase framework.
#
# Usage:
#   Source this file from within a zsh session or framework loader:
#     source /path/to/zbase.zsh
#
# Conventions:
#   - Functions that return a value set $REPLY.
#     Callers MUST read $REPLY — never use $() on these functions.
#   - Internal (private) functions are prefixed with _z::
#   - Debug-only log calls are guarded with z::log::if_debug to eliminate
#     overhead when debug logging is disabled.
#   - Variable values that may contain secrets are never logged.
#   - Silent boolean probes (z::probe::file, z::probe::dir, z::probe::readable,
#     z::probe::writable) emit no errors — callers decide how to handle failure.
#
# Dependencies:
#   z::log::error  z::log::warn  z::log::info  z::log::debug
#   z::log::errorf z::log::debugf
#   z::log::if_debug  z::log::rate_limit  z::log::once  z::log::always
#   z::log::with_context  z::log::remove_context
#   z::log::benchmark_start  z::log::benchmark_end
#   Zsh 5.8+
#
# No dependency on z::config, z::kv, z::sys, z::event, or any other module.
#
# Author: Khodaparastan
# Date:   2026-04-21
# =============================================================================

# =============================================================================
# ERROR CODES
#
# Defined as integer constants so that `return $ZCORE_ERROR_*` always
# produces a non-zero exit status even when the variable is referenced
# before this file is sourced (the typeset -gi ensures global scope).
# =============================================================================

typeset -gi ZCORE_ERROR_GENERAL=1
typeset -gi ZCORE_ERROR_INVALID_INPUT=2
typeset -gi ZCORE_ERROR_NOT_FOUND=3
typeset -gi ZCORE_ERROR_PERMISSION=4

# =============================================================================
# SECTION 1 — OPTION PARSING  (z::opt::*)
# =============================================================================

###
# Get an option value from a zparseopts-produced associative array.
#
# Short option takes precedence over long when both are present.
# Presence is tracked with an explicit matched flag — never by comparing
# the resolved value against the default (which would break when the user
# supplies a value that happens to equal the default).
#
# @param 1: string  - Name of the local -A array (not the array itself)
# @param 2: string  - Short flag letter WITHOUT dash, e.g. "t"; may be ""
# @param 3: string  - Long  flag name  WITHOUT dashes, e.g. "type"; may be ""
# @param 4: string  - Default value when flag is absent (default: "")
# @sets  REPLY      - Resolved option value
# @return 0 always
#
# @example
#   local -A opts
#   zparseopts -D -E -A opts -- t: -type:
#   z::opt::get opts 't' 'type' 'text'
#   local fmt="$REPLY"
###
z::opt::get() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local opts_var="$1" short_opt="$2" long_opt="$3" default_value="${4:-}"
  REPLY="$default_value"

  if [[ -z $opts_var ]]; then
    z::log::error "z::opt::get: opts_var parameter required" \
      param "opts_var"
    return 0
  fi

  # Warn when both flags are empty — likely a caller mistake
  if [[ -z $short_opt && -z $long_opt ]]; then
    z::log::warn "z::opt::get: both short_opt and long_opt are empty; returning default" \
      opts_var "$opts_var"
    return 0
  fi

  # Verify the named variable exists and is an associative array
  if (( ! ${(P)+opts_var} )) || [[ ${(Pt)opts_var} != *association* ]]; then
    return 0
  fi

  local matched=0

  # Short option has higher precedence.
  # ${+assoc[key]} — 1 if key exists in the associative array, 0 otherwise.
  # This is the correct O(1) key-existence check for assoc arrays.
  if [[ -n $short_opt ]] && (( ${+${(P)opts_var}[-${short_opt}]} )); then
    REPLY="${${(P)opts_var}[-${short_opt}]}"
    matched=1
  fi

  # Long option — only when short did not match
  if (( !matched )) && [[ -n $long_opt ]] && (( ${+${(P)opts_var}[--${long_opt}]} )); then
    REPLY="${${(P)opts_var}[--${long_opt}]}"
  fi

  return 0
}

###
# Test whether a flag is present in a zparseopts-produced associative array.
#
# Uses ${+assoc[key]} for direct key-existence check on the associative array —
# O(1), no full-array copy required.
#
# @param 1: string  - Name of the local -A array
# @param 2: string  - Short flag letter WITHOUT dash; may be ""
# @param 3: string  - Long  flag name  WITHOUT dashes; may be ""
# @return 0 if present, 1 if absent
#
# @example
#   local -A opts
#   zparseopts -D -E -A opts -- f -force
#   if z::opt::has opts 'f' 'force'; then
#     echo "force is set"
#   fi
###
z::opt::has() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local opts_var="$1" short_opt="$2" long_opt="$3"

  if [[ -z $opts_var ]]; then
    z::log::error "z::opt::has: opts_var parameter required" \
      param "opts_var"
    return 1
  fi

  if (( ! ${(P)+opts_var} )) || [[ ${(Pt)opts_var} != *association* ]]; then
    return 1
  fi

  # ${+assoc[key]} — correct O(1) key-existence check for associative arrays
  if [[ -n $short_opt ]] && (( ${+${(P)opts_var}[-${short_opt}]} )); then
    return 0
  fi

  if [[ -n $long_opt ]] && (( ${+${(P)opts_var}[--${long_opt}]} )); then
    return 0
  fi

  return 1
}

###
# Parse a generic boolean flag: present → 1, absent → 0.
#
# @param 1: string  - Name of the local -A array
# @param 2: string  - Short flag letter WITHOUT dash
# @param 3: string  - Long  flag name  WITHOUT dashes
# @sets  REPLY      - "1" if present, "0" if absent
# @return 0 always
# @note   Validation errors from z::opt::has are treated as "flag absent" (REPLY=0).
#
# @example
#   local -A opts
#   zparseopts -D -E -A opts -- r -recursive
#   z::opt::parse::bool opts 'r' 'recursive'
#   typeset -i recursive=$REPLY
###
z::opt::parse::bool() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  if z::opt::has "${1:-}" "${2:-}" "${3:-}"; then
    REPLY=1
  else
    REPLY=0
  fi

  return 0
}

# ---------------------------------------------------------------------------
# Internal helper — shared implementation for all single-flag boolean helpers.
#
# @param 1: string  - opts_var name
# @param 2: string  - short flag (without dash)
# @param 3: string  - long  flag (without dashes)
# @param 4: int     - default value: must be 0 or 1
# @param 5: string  - caller name for error messages
# @sets  REPLY      - resolved integer value: 0 or 1
# @return 0 always
# ---------------------------------------------------------------------------
_z::opt::parse::flag() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local opts_var="$1" short_flag="$2" long_flag="$3"
  local caller_name="${5:-z::opt::parse::flag}"
  local raw_default="${4:-0}"

  # Validate that the default is strictly 0 or 1 — silent coercion masks bugs
  if [[ $raw_default != 0 && $raw_default != 1 ]]; then
    z::log::warn "${caller_name}: default value must be 0 or 1, got '${raw_default}'; using 0" \
      caller "$caller_name" \
      default "$raw_default"
    raw_default=0
  fi

  typeset -i flag_val
  (( flag_val = raw_default ))

  if [[ -z $opts_var ]]; then
    z::log::error "${caller_name}: opts_var parameter required" \
      param "opts_var"
    REPLY=$flag_val
    return 0
  fi

  if z::opt::has "$opts_var" "$short_flag" "$long_flag"; then
    (( flag_val = 1 ))
  fi

  REPLY=$flag_val
  return 0
}

###
# Parse --force / -f.
#
# @param 1: string  - Name of the local -A array
# @param 2: int     - Default value when flag absent (default: 0); must be 0 or 1
# @sets  REPLY      - 0 or 1
# @return 0 always
###
z::opt::parse::force() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst
  _z::opt::parse::flag "$1" 'f' 'force' "${2:-0}" 'z::opt::parse::force'
}

