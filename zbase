# =============================================================================
# SECTION 2 — VALIDATION  (z::validate::*)
# =============================================================================

###
# Validate an identifier name.
# Accepted characters: alphanumeric, underscore, hyphen  [[:alnum:]_-]
#
# @param 1: string  - Name to validate
# @param 2: string  - Context label for error messages (default: "Identifier")
# @return 0 if valid, 1 if invalid
#
# @example
#   z::validate::identifier "$alias_name" "Alias name" || return 1
###
z::validate::identifier()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local name="$1" context="${2:-Identifier}"

  if [[ -z $name ]]; then
    z::log::error "${context} cannot be empty" \
      field "$context"
    return 1
  fi

  # [[:alnum:]_-]## — extendedglob: one or more of the allowed character class
  if [[ $name != [[:alnum:]_-]## ]]; then
    z::log::error "Invalid ${context}" \
      field   "$context"               \
      value   "$name"                  \
      allowed "alphanumeric, underscore, hyphen"
    return 1
  fi

  return 0
}

###
# Validate that a value is non-empty.
#
# @param 1: string  - Value to validate
# @param 2: string  - Field label for error messages (default: "Value")
# @return 0 if non-empty, 1 if empty
#
# @example
#   z::validate::nonempty "$value" "Config value" || return 1
###
z::validate::nonempty()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local value="$1" field_name="${2:-Value}"

  if [[ -z $value ]]; then
    z::log::error "${field_name} cannot be empty" \
      field "$field_name"
    return 1
  fi

  return 0
}

###
# Validate that a value is an integer (optional leading minus sign).
#
# @param 1: string  - Value to validate
# @param 2: string  - Field label for error messages (default: "Value")
# @return 0 if valid integer, 1 if invalid
#
# @example
#   z::validate::integer "$port" "Port number" || return 1
###
z::validate::integer()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local value="$1" field_name="${2:-Value}"

  # Pattern: optional leading minus followed by one or more digits
  if [[ $value != (-[0-9]##|[0-9]##) ]]; then
    z::log::error "${field_name} must be an integer" \
      field "$field_name"                            \
      value "$value"
    return 1
  fi

  return 0
}

###
# Validate that an integer falls within an inclusive range.
# Both min and max are independently validated as integers before use.
#
# @param 1: string  - Value to validate
# @param 2: int     - Minimum value (inclusive)
# @param 3: int     - Maximum value (inclusive)
# @param 4: string  - Field label for error messages (default: "Value")
# @return 0 if valid, 1 if invalid
#
# @example
#   z::validate::integer::range "$port" 1 65535 "Port" || return 1
###
z::validate::integer::range()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local value="$1" field_name="${4:-Value}"
  typeset -i min_val max_val int_value

  if [[ -z ${2-} || -z ${3-} ]]; then
    z::log::error "z::validate::integer::range: min and max parameters required" \
      param_2 "${2:-<missing>}"                                                   \
      param_3 "${3:-<missing>}"
    return 1
  fi

  z::validate::integer "$2" "min_val" || return 1
  z::validate::integer "$3" "max_val" || return 1

  (( min_val   = ${2} ))
  (( max_val   = ${3} ))

  z::validate::integer "$value" "$field_name" || return 1
  (( int_value = value ))

  if (( int_value < min_val || int_value > max_val )); then
    z::log::error "${field_name} out of range" \
      field "$field_name"                      \
      value "$int_value"                       \
      min   "$min_val"                         \
      max   "$max_val"
    return 1
  fi

  return 0
}

###
# Validate that a value is one of an allowed set (enum).
#
# @param 1: string  - Pipe-separated allowed values, e.g. "red|green|blue"
# @param 2: string  - Value to validate
# @param 3: string  - Field label for error messages (default: "Value")
# @return 0 if valid, 1 if invalid
#
# @example
#   z::validate::enum "text|json|csv" "$format" "Output format" || return 1
###
z::validate::enum()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local allowed_values="$1" value="$2" field_name="${3:-Value}"
  local -a allowed_array

  if [[ -z $allowed_values ]]; then
    z::log::error "z::validate::enum: allowed_values parameter required" \
      param "allowed_values"
    return 1
  fi

  if [[ -z $value ]]; then
    z::log::error "${field_name} cannot be empty" \
      field   "$field_name"                       \
      allowed "$allowed_values"
    return 1
  fi

  # (s:|:) — split on literal pipe character
  allowed_array=("${(@s:|:)allowed_values}")

  # (I) returns the last matching index; 0 means not found
  if (( ${allowed_array[(I)$value]} == 0 )); then
    z::log::error "Invalid ${field_name}" \
      field   "$field_name"               \
      value   "$value"                    \
      allowed "$allowed_values"
    return 1
  fi

  return 0
}

###
# Validate that a value is a recognised boolean representation.
# Accepted (case-insensitive): 0, 1, true, false, yes, no, on, off
#
# @param 1: string  - Value to validate
# @param 2: string  - Field label for error messages (default: "Value")
# @return 0 if valid, 1 if invalid
#
# @example
#   z::validate::boolean "$enabled" "Enabled flag" || return 1
###
z::validate::boolean()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local value="$1" field_name="${2:-Value}"

  # :l — lowercase modifier; avoids a separate tolower call
  case "${value:l}" in
    0|1|true|false|yes|no|on|off)
      return 0
      ;;
    *)
      z::log::error "Invalid ${field_name}" \
        field   "$field_name"               \
        value   "$value"                    \
        allowed "0, 1, true, false, yes, no, on, off"
      return 1
      ;;
  esac
}

# =============================================================================
# SECTION 3 — PATH PROBING  (z::probe::*)
# =============================================================================

###
# Validate that a path exists, with an optional type constraint.
#
# @param 1: string  - Path to test
# @param 2: string  - Expected type: "file" | "dir" | "any"  (default: "any")
# @param 3: string  - Field label for error messages (default: "Path")
# @return 0 if valid, 1 if invalid
#
# @example
#   z::probe::path "$config" file "Config file" || return 1
#   z::probe::path "$dir"    dir  "Output dir"  || return 1
###
z::probe::path()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local path="$1" path_type="${2:-any}" field_name="${3:-Path}"

  if [[ -z $path ]]; then
    z::log::error "${field_name} cannot be empty" \
      field "$field_name"
    return 1
  fi

  case $path_type in
    file)
      if [[ ! -f $path ]]; then
        z::log::error "${field_name} does not exist or is not a regular file" \
          field "$field_name"                                                  \
          path  "$path"
        return 1
      fi
      ;;
    dir)
      if [[ ! -d $path ]]; then
        z::log::error "${field_name} does not exist or is not a directory" \
          field "$field_name"                                               \
          path  "$path"
        return 1
      fi
      ;;
    any)
      if [[ ! -e $path ]]; then
        z::log::error "${field_name} does not exist" \
          field "$field_name"                         \
          path  "$path"
        return 1
      fi
      ;;
    *)
      z::log::error "z::probe::path: invalid path_type" \
        path_type "$path_type"                           \
        allowed   "file, dir, any"
      return 1
      ;;
  esac

  return 0
}

###
# Validate that a path is readable by the current process.
#
# @param 1: string  - Path to test
# @param 2: string  - Field label for error messages (default: "Path")
# @return 0 if readable, 1 if not
#
# @example
#   z::probe::path::readable "$input" "Input file" || return 1
###
z::probe::path::readable()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local path="$1" field_name="${2:-Path}"

  if [[ -z $path ]]; then
    z::log::error "${field_name} cannot be empty" \
      field "$field_name"
    return 1
  fi

  if [[ ! -r $path ]]; then
    z::log::error "${field_name} is not readable" \
      field "$field_name"                          \
      path  "$path"
    return 1
  fi

  return 0
}

###
# Validate that a path is writable by the current process.
# If the path does not yet exist, the parent directory is checked instead.
# Uses Zsh :h modifier — no dirname subprocess.
#
# @param 1: string  - Path to test
# @param 2: string  - Field label for error messages (default: "Path")
# @return 0 if writable, 1 if not
#
# @example
#   z::probe::path::writable "$output" "Output file" || return 1
###
z::probe::path::writable()
{
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local path="$1" field_name="${2:-Path}"

  if [[ -z $path ]]; then
    z::log::error "${field_name} cannot be empty" \
      field "$field_name"
    return 1
  fi

  if [[ -e $path ]]; then
    if [[ ! -w $path ]]; then
      z::log::error "${field_name} is not writable" \
        field "$field_name"                          \
        path  "$path"
      return 1
    fi
  else
    # Path does not exist yet — check parent directory writability
    local parent_dir="${path:h}"  # :h is Zsh's equivalent of dirname
    if [[ ! -w $parent_dir ]]; then
      z::log::error "${field_name} cannot be created: parent directory not writable" \
        field      "$field_name" \
        path       "$path"       \
        parent_dir "$parent_dir"
      return 1
    fi
  fi

  return 0
}
# =============================================================================
# SECTION 4 — COMMAND & FUNCTION PROBING  (z::probe::cmd, z::probe::func,
#              z::cmd::which, z::func::*)
# =============================================================================

###
# Test whether an external command is available in $PATH.
#
# Uses $+commands — O(1) Zsh hash lookup, no subprocess.
#
# @param 1: string - Command name
# @return 0 if available, ZCORE_ERROR_INVALID_INPUT if empty, 1 if not found
#
# @example
#   if z::probe::cmd "git"; then ...
###
z::probe::cmd() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local cmd="${1:-}"

  z::validate::nonempty "$cmd" "cmd" || return $ZCORE_ERROR_INVALID_INPUT

  # ${+commands[name]} — 1 if key exists in the commands hash, 0 otherwise
  (( ${+commands[$cmd]} ))
}

###
# Return the full path of a command.
# Sets $REPLY — never use $() to call this function.
#
# @param 1:  string - Command name
# @sets $REPLY      - Full path if found, empty string if not
# @return 0 if found, ZCORE_ERROR_NOT_FOUND if not found
#
# @example
#   z::cmd::which "git"; local git_path="$REPLY"
###
z::cmd::which() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local cmd="${1:-}"
  REPLY=""

  z::validate::nonempty "$cmd" "cmd" || return $ZCORE_ERROR_INVALID_INPUT

  if ! z::probe::cmd "$cmd"; then
    z::log::error "Command not found" cmd "$cmd"
    return $ZCORE_ERROR_NOT_FOUND
  fi

  REPLY="${commands[$cmd]}"
  return 0
}

###
# Test whether a Zsh function is defined in the current session.
#
# Uses $+functions — O(1) Zsh hash lookup, no subprocess.
#
# @param 1: string - Function name
# @return 0 if defined, ZCORE_ERROR_INVALID_INPUT if empty, 1 if not found
#
# @example
#   if z::probe::func "my::handler"; then ...
###
z::probe::func() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local func="${1:-}"

  z::validate::nonempty "$func" "func" || return $ZCORE_ERROR_INVALID_INPUT

  # ${+functions[name]} — 1 if function is defined, 0 otherwise
  (( ${+functions[$func]} ))
}

###
# Call a function by name with arguments.
# Validates existence before calling — no special-case suppression lists.
# PIL3 event emission is the caller's responsibility.
#
# @param 1:   string - Function name
# @param ...: any    - Arguments forwarded to the function
# @return Function exit code, or ZCORE_ERROR_* on validation failure
#
# @example
#   z::func::call "my::handler" arg1 arg2
###
z::func::call() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local func="${1:-}"

  z::validate::nonempty "$func" "func" || return $ZCORE_ERROR_INVALID_INPUT
  shift

  if ! z::probe::func "$func"; then
    z::log::warn "Function not found" func "$func"
    return $ZCORE_ERROR_NOT_FOUND
  fi

  typeset -i exit_code=0
  "$func" "$@" || exit_code=$?

  if (( exit_code != 0 )); then
    z::log::debug "Function returned non-zero" func "$func" exit_code "$exit_code"
  fi

  return $exit_code
}

###
# Unset a function by name.
#
# @param 1: string - Function name
# @return 0 on success, ZCORE_ERROR_* on failure
#
# @example
#   z::func::unset "my::old::handler"
###
z::func::unset() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local target="${1:-}"

  z::validate::nonempty "$target" "func" || return $ZCORE_ERROR_INVALID_INPUT

  if ! (( ${+functions[$target]} )); then
    return $ZCORE_ERROR_NOT_FOUND
  fi

  if unset -f -- "$target"; then
    z::log::debug "Function unset" func "$target"
    return 0
  fi

  return $ZCORE_ERROR_GENERAL
}

###
# List all defined functions matching a glob pattern.
#
# @param 1: string - Glob pattern (optional, default: *)
# @stdout  One function name per line, sorted
# @return 0 always
#
# @example
#   z::func::list "z::kv::*"
###
z::func::list() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local pattern="${1:-*}"

  # (Mok) — M: keep only matching, o: sort ascending, k: keys of functions hash
  # ${~pattern} — force glob expansion of the pattern variable
  local func
  for func in ${(Mok)functions:#${~pattern}}; do
    print -r -- "$func"
  done
  return 0
}

# =============================================================================
# SECTION 5 — VARIABLE MANAGEMENT  (z::probe::var, z::var::*)
# =============================================================================

###
# Test whether a parameter (variable) is defined.
#
# @param 1: string - Variable name
# @return 0 if defined, ZCORE_ERROR_INVALID_INPUT if empty, 1 if not defined
#
# @example
#   if z::probe::var "MY_CONFIG"; then ...
###
z::probe::var() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local name="${1:-}"

  z::validate::nonempty "$name" "name" || return $ZCORE_ERROR_INVALID_INPUT

  # ${+parameters[name]} — 1 if the parameter is set, 0 otherwise
  (( ${+parameters[$name]} ))
}

###
# Get the value of a variable by name.
# Sets $REPLY — never use $() to call this function.
#
# @param 1: string - Variable name
# @param 2: string - Default value if variable is not defined (default: "")
# @sets $REPLY     - Variable value or default
# @return 0 always
#
# @example
#   z::var::get "MY_TIMEOUT" "30"; local timeout="$REPLY"
###
z::var::get() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local name="${1:-}" default="${2:-}"
  REPLY="$default"

  if [[ -z $name ]]; then
    return 0
  fi

  if z::probe::var "$name"; then
    REPLY="${(P)name}"  # (P) — indirect expansion: value of the variable named by $name
  fi

  return 0
}

###
# Set a global variable by name.
#
# @param 1: string - Variable name
# @param 2: string - Value to assign
# @return 0 on success, ZCORE_ERROR_INVALID_INPUT if name is empty
#
# @example
#   z::var::set "MY_CONFIG" "/etc/app.conf"
###
z::var::set() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local name="${1:-}" value="${2:-}"

  z::validate::nonempty "$name" "name" || return $ZCORE_ERROR_INVALID_INPUT

  typeset -g "$name=$value"
  z::log::debug "Variable set" name "$name" value "$value"

  return 0
}

###
# Unset a variable by name.
# Refuses to unset readonly variables.
#
# @param 1: string - Variable name
# @return 0 on success, ZCORE_ERROR_* on failure
#
# @example
#   z::var::unset "MY_TEMP_VAR"
###
z::var::unset() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local target="${1:-}"

  z::validate::nonempty "$target" "name" || return $ZCORE_ERROR_INVALID_INPUT

  if ! (( ${+parameters[$target]} )); then
    return $ZCORE_ERROR_NOT_FOUND
  fi

  # (tP) — parameter type flags via indirect expansion; check for readonly
  if [[ ${(tP)target} == *readonly* ]]; then
    z::log::error "Cannot unset readonly variable" name "$target"
    return $ZCORE_ERROR_PERMISSION
  fi

  if unset -v -- "$target"; then
    z::log::debug "Variable unset" name "$target"
    return 0
  fi

  return $ZCORE_ERROR_GENERAL
}

