# =============================================================================
# SECTION 7 — ENVIRONMENT MANAGEMENT  (z::env::*)
#
# Path normalization uses only tilde expansion via parameter substitution
# and the :A modifier for absolute path resolution — no subprocesses.
# =============================================================================

###
# Normalize a path using pure Zsh.
# Handles ~, ~+, ~-, and relative paths.
# Sets $REPLY to the normalized absolute path.
#
# @param 1:  string - Path to normalize
# @sets $REPLY      - Normalized absolute path
# @return 0 always
# @private
###
_z::env::normalize_path() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local path="$1"
  REPLY=""

  # Use quoted prefix patterns to avoid tilde interpretation issues
  case $path in
    '~')          path="$HOME"                        ;;
    '~/'*)        path="${HOME}/${path#'~/'}"          ;;
    '~+'|'~+/'*)  path="${PWD}${path#'~+'}"            ;;  # ~+ expands to $PWD
    '~-'|'~-/'*)  path="${OLDPWD:-$PWD}${path#'~-'}"  ;;  # ~- expands to $OLDPWD
    [^/]*)        path="${PWD%/}/$path"               ;;  # relative path — prepend CWD
  esac

  # :A — resolve symlinks and canonicalize to absolute path (no subprocess)
  REPLY="${path:A}"
  return 0
}

###
# Add a directory to PATH.
# Normalizes path using pure Zsh — no subprocess.
# Skips silently if directory does not exist or is already in PATH.
# Uses z::log::once for the "already in PATH" notice to prevent log spam
# when called repeatedly (e.g., in a loop or re-sourced config).
#
# @param 1: string - Directory path
# @param 2: string - Position: "prepend" | "append" (default: "append")
# @return 0 on success, ZCORE_ERROR_* on failure
#
# @example
#   z::env::path_add "$HOME/.local/bin" prepend
###
z::env::path_add() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local dir="${1:-}"
  local position="${2:-append}"

  z::validate::nonempty "$dir" "dir"                         || return $ZCORE_ERROR_INVALID_INPUT
  z::validate::enum "prepend|append" "$position" "position"  || return $ZCORE_ERROR_INVALID_INPUT

  _z::env::normalize_path "$dir"
  dir="$REPLY"

  if [[ ! -d $dir ]]; then
    if z::log::if_debug; then
      z::log::debug "Directory does not exist, skipping PATH add" dir "$dir"
    fi
    return $ZCORE_ERROR_NOT_FOUND
  fi

  # Sentinel colons prevent false partial matches (e.g. /usr matching /usr/local)
  if [[ ":${PATH}:" == *":${dir}:"* ]]; then
    # Use once to suppress repeated "already in PATH" noise in re-sourced configs
    z::log::once "path-already-has-${dir}" debug \
      "Directory already in PATH" dir "$dir"
    return 0
  fi

  case $position in
    prepend) export PATH="${dir}:${PATH}" ;;
    append)  export PATH="${PATH}:${dir}" ;;
  esac

  # Flush the command hash table so newly added paths are found immediately
  builtin hash -r 2>/dev/null

  if z::log::if_debug; then
    z::log::debug "Added to PATH" dir "$dir" position "$position"
  fi
  return 0
}

###
# Remove a directory from PATH.
# Normalizes path using pure Zsh.
#
# @param 1: string - Directory path to remove
# @return 0 on success, ZCORE_ERROR_INVALID_INPUT if empty
#
# @example
#   z::env::path_remove "$HOME/.local/bin"
###
z::env::path_remove() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local dir="${1:-}"

  z::validate::nonempty "$dir" "dir" || return $ZCORE_ERROR_INVALID_INPUT

  _z::env::normalize_path "$dir"
  dir="$REPLY"

  # Split PATH on ':', filter out the target dir, then rejoin with ':'
  local -a path_array
  path_array=("${(s.:.)PATH}")
  path_array=("${path_array[@]:#$dir}")
  export PATH="${(j.:.)path_array}"

  # Flush the command hash table after modifying PATH
  builtin hash -r 2>/dev/null

  if z::log::if_debug; then
    z::log::debug "Removed from PATH" dir "$dir"
  fi
  return 0
}

###
# Test whether a directory is in PATH.
# Normalizes the path before checking for consistency with path_add/path_remove.
#
# @param 1: string - Directory path
# @return 0 if present, ZCORE_ERROR_INVALID_INPUT if empty, 1 if absent
###
z::env::path_has() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local dir="${1:-}"

  z::validate::nonempty "$dir" "dir" || return $ZCORE_ERROR_INVALID_INPUT

  _z::env::normalize_path "$dir"
  dir="$REPLY"

  # Sentinel colons prevent false partial matches
  [[ ":${PATH}:" == *":${dir}:"* ]]
}

###
# Create a shell alias.
#
# @param 1: string - Alias name (no spaces, no = sign)
# @param 2: string - Alias value
# @return 0 on success, ZCORE_ERROR_* on failure
#
# @example
#   z::env::alias_set "ll" "ls -lah"
###
z::env::alias_set() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local alias_name="${1:-}" alias_value="${2:-}"

  z::validate::nonempty "$alias_name"  "alias_name"  || return $ZCORE_ERROR_INVALID_INPUT
  z::validate::nonempty "$alias_value" "alias_value" || return $ZCORE_ERROR_INVALID_INPUT

  # Glob check is faster than regex for simple character membership tests
  if [[ $alias_name == *[[:space:]=]* ]]; then
    z::log::error "Invalid alias name: contains spaces or equals sign" \
      name "$alias_name"
    return $ZCORE_ERROR_INVALID_INPUT
  fi

  if ! builtin alias "${alias_name}=${alias_value}"; then
    z::log::error "Failed to create alias" name "$alias_name"
    return $ZCORE_ERROR_GENERAL
  fi

  if z::log::if_debug; then
    z::log::debug "Alias created" name "$alias_name" value "$alias_value"
  fi
  return 0
}

###
# Remove a shell alias.
#
# @param 1: string - Alias name
# @return 0 on success, ZCORE_ERROR_* on failure
#
# @example
#   z::env::alias_unset "ll"
###
z::env::alias_unset() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local alias_name="${1:-}"

  z::validate::nonempty "$alias_name" "alias_name" || return $ZCORE_ERROR_INVALID_INPUT

  if ! builtin unalias "$alias_name"; then
    if z::log::if_debug; then
      z::log::debug "Alias not found" name "$alias_name"
    fi
    return $ZCORE_ERROR_NOT_FOUND
  fi

  if z::log::if_debug; then
    z::log::debug "Alias removed" name "$alias_name"
  fi
  return 0
}

###
# Export a variable to the environment.
#
# NOTE: Values are intentionally not logged to prevent secret leakage.
# NOTE: Uses typeset -gx with -- to prevent flag injection.
#
# @param 1: string - Variable name
# @param 2: string - Value
# @return 0 on success, ZCORE_ERROR_INVALID_INPUT if name is empty
#
# @example
#   z::env::export "APP_ENV" "production"
###
z::env::export() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local name="${1:-}" value="${2:-}"

  z::validate::nonempty "$name" "name" || return $ZCORE_ERROR_INVALID_INPUT

  # typeset -gx with -- prevents flag injection if $name starts with '-'
  typeset -gx -- "${name}=${value}"

  if z::log::if_debug; then
    # Value is intentionally omitted — may contain secrets
    z::log::debug "Variable exported" name "$name"
  fi
  return 0
}

# =============================================================================
# SECTION 8 — EXECUTION SAFETY VALIDATORS  (_z::exec::*, z::exec::scan,
#              z::exec::is_safe)
#
# Pure safety analysis — no side effects beyond logging.
# Detection is heuristic and best-effort. Known limitations:
#   - Does not detect `cmd | sudo sh` (sudo as a prefix before shell)
#   - Fork bomb detection covers the canonical `:() { :|: & }` form only;
#     variants like `a(){ a|a& };a` are not detected
#   - Static tokenization via (z) does not handle all quoting edge cases
# =============================================================================

# Pre-compiled ERE patterns stored in variables.
# Zsh caches compiled regexes when the RHS of =~ is a variable, not a literal.
typeset -g _ZBASE_EXEC_INIT_CMD_RE='(starship|mise|direnv|zoxide|atuin|mcfly|fzf|oh-my-posh)[[:space:]]+init([[:space:]]|$)'
typeset -g _ZBASE_EXEC_META_RE='[;&()]'
typeset -g _ZBASE_EXEC_FORK_BOMB_1_RE=':\(\)'
typeset -g _ZBASE_EXEC_FORK_BOMB_2_RE=':\|:'

###
# Detect shell tool init commands — these are exempt from safety scanning
# as they are known-safe patterns from trusted tools.
#
# @param 1: string - Command string to test
# @return 0 if init command, 1 otherwise
# @private
###
_z::exec::is_init_cmd() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local input="$1"
  [[ $input =~ $_ZBASE_EXEC_INIT_CMD_RE ]]
}

###
# Detect dangerous shell metacharacters in a command string.
#
# @param 1: string - Command string to test
# @return 0 if dangerous chars found, 1 if clean
# @private
###
_z::exec::has_dangerous_metachars() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local input="$1"
  [[ -z $input ]] && return 1
  # Semicolons, ampersands, parens, and backticks can chain or subshell commands
  [[ $input =~ $_ZBASE_EXEC_META_RE ]] || [[ $input == *'`'* ]]
}

###
# Check a single parsed command segment for dangerous patterns.
# Detects: destructive rm -rf / --recursive --force on root/home paths,
# dd writes to raw block devices.
# Single-pass flag and path collection for rm.
#
# @param 1:   string - Command name
# @param ...: string - Command arguments
# @return 0 if safe, 1 if dangerous
# @private
###
_z::exec::check_segment() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local cmd="$1"
  shift
  local -a args
  (( $# > 0 )) && args=("$@")

  if [[ $cmd == rm ]]; then
    typeset -i have_r=0 have_f=0
    local -a dangerous_paths=()
    local a

    # Single pass: collect flags and paths simultaneously
    for a in "${args[@]}"; do
      case $a in
        --recursive)          (( have_r = 1 ))                ;;
        --force)              (( have_f = 1 ))                ;;
        --*)                  ;;  # other long options — skip
        -*)
          [[ $a == *r* ]] && (( have_r = 1 ))
          [[ $a == *f* ]] && (( have_f = 1 ))
          ;;
        /|/*|~|~/*|'$HOME'|'$HOME'/*)
          dangerous_paths+=("$a")
          ;;
      esac
    done

    if (( have_r && have_f && ${#dangerous_paths} > 0 )); then
      z::log::error "Dangerous rm detected" \
        cmd  "rm"                            \
        path "${dangerous_paths[1]}"
      return 1
    fi
  fi

  if [[ $cmd == dd ]]; then
    local kv dev base
    for kv in "${args[@]}"; do
      if [[ $kv == of=/dev/* ]]; then
        dev="${kv#of=}"
        base="${dev#/dev/}"
        case $base in
          sd*|hd*|nvme*|disk*|rdisk*)
            z::log::error "Dangerous dd detected" \
              cmd    "dd"                          \
              device "$dev"
            return 1
            ;;
        esac
      fi
    done
  fi

  return 0
}

###
# Scan a full command string for dangerous patterns.
# Tokenizes via Zsh (z) flag — no subprocess.
# Checks: pipe-to-shell, fork bomb, per-segment dangerous commands.
#
# Known limitations: see section header comment.
#
# @param 1: string - Command string to scan
# @return 0 if safe, 1 if dangerous pattern detected
# @private
###
_z::exec::scan_patterns() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local input="${1:-}"
  [[ -z $input ]] && return 0

  if _z::exec::is_init_cmd "$input"; then
    return 0
  fi

  # "${(z)input}" — tokenize using shell word-splitting rules, no subprocess.
  # Quoted to preserve empty tokens from quoted empty arguments.
  local -a words
  words=("${(z)input}")
  (( ${#words} == 0 )) && return 0

  typeset -i i j
  local next_cmd base

  # Scan for pipe-to-shell patterns: cmd | sh / bash / zsh / etc.
  for (( i = 1; i <= ${#words}; i++ )); do
    if [[ ${words[i]} == '|' ]]; then
      (( j = i + 1 ))
      next_cmd=""
      while (( j <= ${#words} )); do
        case ${words[j]} in
          '|'|'||'|'&&'|';'|'&') break ;;
          # Skip command prefixes that don't change the effective command.
          # Note: "cmd | sudo sh" is NOT detected — sudo is treated as a prefix.
          # This is a known limitation of static analysis without full parsing.
          nocorrect|noglob|builtin|command|exec|time|nice|nohup|sudo|doas|env)
            (( j += 1 ))
            continue
            ;;
          # Skip leading VAR=value assignments
          [[:alpha:]_][[:alnum:]_]*=*)
            (( j += 1 ))
            continue
            ;;
        esac
        next_cmd="${words[j]}"
        break
      done
      if [[ -n ${next_cmd:-} ]]; then
        base="${next_cmd:t}"  # :t — tail (basename) of the path
        case $base in
          sh|bash|zsh|ksh|dash)
            z::log::rate_limit "exec-pipe-shell" 5 60 error \
              "Dangerous pattern: pipe to shell"             \
              shell "$base"                                  \
              input "$input"
            return 1
            ;;
        esac
      fi
    fi
  done

  # Detect fork bomb pattern: :() { :|: & }
  # Note: variant forms like `a(){ a|a& };a` are not detected.
  if [[ $input =~ $_ZBASE_EXEC_FORK_BOMB_1_RE && $input =~ $_ZBASE_EXEC_FORK_BOMB_2_RE ]]; then
    z::log::rate_limit "exec-fork-bomb" 3 60 error \
      "Dangerous pattern: fork bomb detected"       \
      input "$input"
    return 1
  fi

  # Walk tokens and dispatch each pipeline segment to _z::exec::check_segment
  local -a seg=()
  local w
  for w in "${words[@]}"; do
    case $w in
      '|'|'||'|'&&'|';'|'&')
        # Segment boundary — check accumulated segment, then reset
        if (( ${#seg} )); then
          local cmd="${seg[1]}"
          local -a seg_args=("${(@)seg[2,-1]}")
          _z::exec::check_segment "$cmd" "${seg_args[@]}" || return 1
          seg=()
        fi
        ;;
      # Skip command prefixes only at the start of a segment
      nocorrect|noglob|builtin|command|exec|time|nice|nohup|sudo|doas|env)
        if (( ${#seg} == 0 )); then
          continue
        else
          seg+=("$w")
        fi
        ;;
      # Skip leading VAR=value assignments only at the start of a segment
      [[:alpha:]_][[:alnum:]_]*=*)
        if (( ${#seg} == 0 )); then
          continue
        else
          seg+=("$w")
        fi
        ;;
      *)
        seg+=("$w")
        ;;
    esac
  done

  # Check the final segment (no trailing delimiter)
  if (( ${#seg} )); then
    local cmd="${seg[1]}"
    local -a seg_args=("${(@)seg[2,-1]}")
    _z::exec::check_segment "$cmd" "${seg_args[@]}" || return 1
  fi

  return 0
}

###
# Public interface: scan a command string for dangerous patterns.
#
# @param 1: string - Command string to scan
# @return 0 if safe, 1 if dangerous, ZCORE_ERROR_INVALID_INPUT if empty
#
# @example
#   z::exec::scan "cat file | bash" || return 1
###
z::exec::scan() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  local input="${1:-}"

  z::validate::nonempty "$input" "input" || return $ZCORE_ERROR_INVALID_INPUT

  _z::exec::scan_patterns "$input"
}

###
# Alias for z::exec::scan — semantic sugar for conditional use.
#
# @param 1: string - Command string to test
# @return 0 if safe, 1 if dangerous
#
# @example
#   if z::exec::is_safe "$cmd"; then z::exec::run "$cmd"; fi
###
z::exec::is_safe() {
  emulate -L zsh
  setopt extendedglob warncreateglobal typesetsilent noshortloops nopromptsubst

  z::exec::scan "$@"
}

# =============================================================================
# FRAMEWORK LOAD AUDIT
# Emit a single always-on log entry when zbase is sourced.
# This creates an audit trail for framework lifecycle events.
# =============================================================================
z::log::always "zbase loaded" \
  module  "zbase"             \
  version "1.0.0"             \
  pid     "$$"
