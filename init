#!/usr/bin/env zsh
# Z shell entry point — sourced by zsh on interactive startup.

if [[ -n "${_zcore_init_loaded:-}" ]]; then
  return 0
fi

setopt PROMPT_SUBST promptpercent
umask 022
zstyle ":plugin:zconvey" greeting "none"

typeset -gx ZCORE_LIBDIR="${ZDOTDIR}"
typeset -gx ZCORE_MODDIR="${ZDOTDIR}/modules"
typeset -gx ZCORE_LOGDIR="${ZDOTDIR}/logs"

# Critical modules — init fails if any of these do not load.
typeset -ga _ZCORE_CRITICAL_MODULES=(environment options)

# ---------------------------------------------------------------------------
# Logging bootstrap
# ---------------------------------------------------------------------------
z::interactive::_ensure_logdir() {
  emulate -L zsh
  setopt local_options typeset_silent

  if z::probe::dir "$ZCORE_LOGDIR"; then
    return 0
  fi

  if command mkdir -p -- "$ZCORE_LOGDIR" 2>/dev/null; then
    z::log::debug "Created log directory: $ZCORE_LOGDIR"
    return 0
  fi

  z::log::warn "Failed to create log directory: $ZCORE_LOGDIR"
  return $ZBASE_ERROR_GENERAL
}

z::interactive::_init_log() {
  emulate -L zsh
  setopt local_options typeset_silent
  local saved_show_progress=true

  if z::config::get show_progress 2>/dev/null; then
    saved_show_progress="$REPLY"
  fi

  # Suppress progress only while configuring the logger; restore user preference after.
  z::progress::disable
  __z::log::init_colors
  z::interactive::_ensure_logdir
  z::log::set_file "${ZCORE_LOGDIR}/init.log"
  z::log::set_file_level info
  z::log::set_format "text"
  z::log::set_level warn
  z::log::set_rotation 1
  z::log::set_max_size $((10 * 1024 * 1024)) # 10 MiB
  z::log::set_max_files 5
  z::log::enable_buffering 1000
  z::log::enable_performance_mode
  z::config::set show_progress "$saved_show_progress"
  z::log::info "Zsh initialization started" \
    zsh_version "$ZSH_VERSION" \
    zdotdir "$ZDOTDIR" \
    shell_pid "$$"
  return 0
}

# ---------------------------------------------------------------------------
# Post-init configuration (from zkv config store)
# ---------------------------------------------------------------------------
z::interactive::_apply_config() {
  emulate -L zsh
  setopt local_options typeset_silent

  if z::config::get log_level 2>/dev/null; then
    z::log::set_level "$REPLY"
  fi

  if z::config::get performance_mode 2>/dev/null && [[ $REPLY == true ]]; then
    typeset -gi _ZBASE_PERF_MODE=1
    z::log::enable_performance_mode 2>/dev/null
    (( ${+functions[z::bus::enable_performance_mode]} )) &&
      z::bus::enable_performance_mode 2>/dev/null
    (( ${+functions[z::kv::enable_performance_mode]} )) &&
      z::kv::enable_performance_mode config 2>/dev/null
  fi

  return 0
}

# ---------------------------------------------------------------------------
# Module loader
#
# Do not use emulate -L or local_options here — sourced modules set global
# shell options (setpath, options) and must persist after load_mods returns.
# ---------------------------------------------------------------------------
z::interactive::load_mods() {
  setopt typeset_silent

  # environment must precede options (HISTFILE/XDG); setpath follows environment.
  local -ar modules=(
    environment
    setpath
    options
    ziplug
    completions
    ls-enhancements
    python
    clipboard
    external-tool-integrations
    prompt
    keybindings
    aliases
    zoxide
  )

  local -i loaded=0 processed=0 total=${#modules[@]} show_progress=0 warnings=0 failures=0
  local -a progress_flags=()
  local module full_path module_start module_status=""
  typeset -g _z_init_start=${EPOCHREALTIME:-$SECONDS}

  if z::config::get show_progress 2>/dev/null && [[ $REPLY == true ]]; then
    show_progress=1
  fi

  progress_flags=(--since "$_z_init_start")
  if ((${_zlog_config[level]:-2} >= _ZLOG_LEVEL_INFO)); then
    progress_flags+=(--newline)
  fi

  if ((show_progress)); then
    z::progress::phase "loading modules" "$total"
  fi

  z::log::info "Loading ${total} configuration modules..."

  for module in "${modules[@]}"; do
    module_start=${EPOCHREALTIME:-$SECONDS}
    module_status=ok

    if ((show_progress)); then
      z::progress::show "$processed" "$total" "$module" --active "${progress_flags[@]}"
    fi

    full_path="${ZCORE_MODDIR}/${module}.zsh"

    if [[ ! -f "$full_path" ]]; then
      module_status=fail
      ((warnings++))
      z::log::warn "Module file not found: ${module}.zsh"
      if (( ${_ZCORE_CRITICAL_MODULES[(Ie)$module]} )); then
        ((failures++))
      fi
    elif z::file::source --global "$full_path"; then
      ((loaded++))
      z::log::debug "Module loaded: ${module}.zsh"
      if ((${_zlog_config[level]:-2} >= _ZLOG_LEVEL_DEBUG)) &&
        __z::ui::elapsed_since "$module_start"; then
        local -F module_elapsed=$REPLY module_timing
        if ((module_elapsed > 0.2)); then
          module_timing=$(z::util::duration "$module_elapsed")
          module_timing=${module_timing%%$'\n'*}
          z::log::debug "Module slow: ${module}.zsh (${module_timing})"
        fi
      fi
    else
      module_status=fail
      ((warnings++))
      z::log::warn "Failed to load module: ${module}.zsh"
      if (( ${_ZCORE_CRITICAL_MODULES[(Ie)$module]} )); then
        ((failures++))
      fi
    fi

    ((processed++))

    if ((show_progress)) && [[ $module_status != ok ]]; then
      local -a post_flags=("${progress_flags[@]}")
      case $module_status in
      fail) post_flags+=(--fail) ;;
      skip) post_flags+=(--skip) ;;
      esac
      z::progress::show "$processed" "$total" "$module" "${post_flags[@]}"
    fi
  done

  if ((show_progress)); then
    z::progress::show "$total" "$total" "ready" "${progress_flags[@]}"
    z::progress::finish "zcore ready" \
      --since "$_z_init_start" \
      --total "$total" \
      --loaded "$loaded" \
      --warnings "$warnings"
  fi

  z::log::info "Successfully loaded ${loaded}/${total} modules." \
    warnings "$warnings" \
    failures "$failures"

  if ((failures)); then
    z::log::error "Critical module load failures: ${failures}"
    return $ZCORE_ERROR_GENERAL
  fi

  return 0
}

# ---------------------------------------------------------------------------
# Library loader
# ---------------------------------------------------------------------------
z::interactive::load_libs() {
  emulate -L zsh
  setopt local_options typeset_silent

  local -a libs=(zlog zbase ui zkv zbus z)
  local lib lib_path

  # zlog must load first; clamp console before other libs source (default is DEBUG).
  lib_path="$ZDOTDIR/zlog"
  if [[ ! -r "$lib_path" ]]; then
    print -ru2 -- "zcore: required library not found: $lib_path"
    return $ZCORE_ERROR_NOT_FOUND
  fi
  if ! source "$lib_path"; then
    print -ru2 -- "zcore: failed to source library: zlog"
    return $ZCORE_ERROR_GENERAL
  fi
  z::log::set_level warn

  for lib in "${libs[@]:1}"; do
    lib_path="$ZDOTDIR/$lib"
    if [[ ! -r "$lib_path" ]]; then
      print -ru2 -- "zcore: required library not found: $lib_path"
      return $ZCORE_ERROR_NOT_FOUND
    fi
    if ! source "$lib_path"; then
      print -ru2 -- "zcore: failed to source library: $lib"
      return $ZCORE_ERROR_GENERAL
    fi
  done

  return 0
}

# ---------------------------------------------------------------------------
# Master init
#
# Avoid emulate -L around load_mods — it prevents setopt from sourced modules
# from persisting in the interactive shell.
# ---------------------------------------------------------------------------
z::interactive::init() {
  setopt typeset_silent

  # Lean module loading — only `b:` (builtins) features needed.
  zmodload -F zsh/mathfunc
  zmodload zsh/parameter zsh/nearcolor

  z::interactive::load_libs || return $?
  z::sys::platform
  z::interactive::_init_log

  # Skip symlink resolution while sourcing trusted local modules.
  local -i _saved_zbase_perf_mode=_ZBASE_PERF_MODE
  _ZBASE_PERF_MODE=1

  z::interactive::load_mods || return $?

  _ZBASE_PERF_MODE=$_saved_zbase_perf_mode
  z::interactive::_apply_config

  # Verify shell options persisted (must not use local_options above).
  if ! [[ -o EXTENDED_HISTORY ]]; then
    z::log::error "History options not applied — check module load order"
    return $ZCORE_ERROR_GENERAL
  fi

  if (( ${+functions[z::event::emit]} )); then
    z::event::emit "zcore:session_ready" "$ZCORE_VERSION" 2>/dev/null || true
  fi

  z::log::info "Zsh initialization complete"

  typeset -g _zcore_init_loaded=1
  return 0
}

z::interactive::cleanup() {
  emulate -L zsh
  setopt local_options typeset_silent
  unset -f -- \
    z::interactive::init \
    z::interactive::load_mods \
    z::interactive::load_libs \
    z::interactive::_init_log \
    z::interactive::_ensure_logdir \
    z::interactive::_apply_config \
    z::interactive::cleanup
}

if [[ -o interactive ]]; then
  if ! z::interactive::init; then
    print -ru2 -- "Zsh initialization failed"
    z::interactive::cleanup
    return 1
  fi
  z::interactive::cleanup
  z::log::flush
  z::log::disable_performance_mode
fi

return 0
